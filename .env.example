# Railway 会自动注入 DATABASE_URL
# 本地开发需要手动配置
DATABASE_URL="postgresql://user:password@localhost:5432/gesp_ai"

JWT_SECRET="your-jwt-secret-here"

# 初始管理员邮箱（仅该邮箱注册时获得 admin 权限）
INITIAL_ADMIN_EMAIL=""

ANTHROPIC_API_KEY="your-anthropic-api-key"

# 虎皮椒支付（开通账号后填入，https://www.xunhupay.com）
XUNHU_APPID="your-xunhu-appid"
XUNHU_APPSECRET="your-xunhu-appsecret"
XUNHU_API_URL="https://api.xunhupay.com/payment/do.html"

# 站点域名（用于支付回调 URL 等，不带末尾斜杠）
SITE_ORIGIN="https://gesp.ai"

# Judge0 判题服务（RapidAPI）
JUDGE0_API_KEY="your-judge0-rapidapi-key"

# Resend 邮件服务（注册/重置密码验证码）
RESEND_API_KEY="re_xxx"

# 信任的反向代理 hop 数（Railway / 大多数 PaaS 填 1）
TRUSTED_PROXY_HOPS="1"

# Sentry 错误监控（可选；留空则完全不启用上报）
# 服务端 + 客户端分开配，客户端的 DSN 必须以 NEXT_PUBLIC_ 开头才能在浏览器读到
# 可以填同一个项目的同一个 DSN
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
