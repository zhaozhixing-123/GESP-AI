generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique       // 登录标识
  emailVerified       Boolean              @default(false)
  nickname            String                             // 展示昵称
  passwordHash        String
  role                String               @default("user") // admin | user
  createdAt           DateTime             @default(now())
  parentPassword      String?              // 家长密码（bcrypt hash）
  feishuWebhook       String?              // 飞书 Webhook URL
  notifyThresholdMin  Int                  @default(2) // 分心多少分钟通知家长
  lastNotifyFocusMs   Int                  @default(0) // 上次通知时的累计专注值（ms），用于服务端增量计算
  lastNotifyDistractMs Int                 @default(0) // 上次通知时的累计分心值（ms）
  tokenVersion        Int                  @default(0) // 改密时递增，旧 JWT 自动失效
  // 账户扩展字段
  phone               String?              // 手机号（选填）
  targetLevel         Int?                 // 目标考试级别 3-8
  examDate            DateTime?            // 目标考试日期
  plan                String               @default("free") // free | monthly | quarterly | yearly
  planExpireAt        DateTime?            // 订阅到期时间，null = 免费用户
  isInternal          Boolean              @default(false) // 内部测试账号，全面板统计排除
  submissions         Submission[]
  wrongBooks          WrongBook[]
  chatHistory         ChatHistory[]
  wrongBookAnalyses   WrongBookAnalysis[]
  orders              Order[]
  variantUnlocks      VariantUnlock[]
  variantSubmissions  VariantSubmission[]
  dailyFocusLogs     DailyFocusLog[]
}

model Problem {
  id                  Int                  @id @default(autoincrement())
  luoguId             String               @unique
  title               String
  level               Int                  // 1-8 GESP级别
  description         String
  inputFormat         String
  outputFormat        String
  samples             String               // JSON: [{input, output}]
  testCases           String               // JSON: [{input, output}]
  tags                String               @default("[]") // JSON: ["递推/递归", "动态规划"]
  verifiedAt          DateTime?            // 上次复核时间
  verifiedCount       Int                  @default(0) // 复核通过的测试点数
  submissions         Submission[]
  wrongBooks          WrongBook[]
  chatHistory         ChatHistory[]
  wrongBookAnalyses   WrongBookAnalysis[]
  variants            VariantProblem[]
  variantUnlocks      VariantUnlock[]
}

model Submission {
  id                  Int                  @id @default(autoincrement())
  userId              Int
  problemId           Int
  code                String
  language            String               @default("cpp")
  status              String               // AC, WA, TLE, CE, RE, MLE
  timeUsed            Int?                 // ms
  memoryUsed          Int?                 // KB
  createdAt           DateTime             @default(now())
  user                User                 @relation(fields: [userId], references: [id])
  problem             Problem              @relation(fields: [problemId], references: [id])
  wrongBookAnalyses   WrongBookAnalysis[]
}

model WrongBook {
  id        Int      @id @default(autoincrement())
  userId    Int
  problemId Int?                // null 时表示这是变形题错题
  variantId Int?                // 变形题 ID（与 problemId 二选一）
  addedAt   DateTime @default(now())
  user      User            @relation(fields: [userId], references: [id])
  problem   Problem?        @relation(fields: [problemId], references: [id])
  variant   VariantProblem? @relation(fields: [variantId], references: [id])

  @@unique([userId, problemId])
  @@unique([userId, variantId])
}

model WrongBookAnalysis {
  id                  Int        @id @default(autoincrement())
  userId              Int
  problemId           Int?                // null 时表示变形题分析
  variantId           Int?                // 变形题 ID（与 problemId 二选一）
  submissionId        Int?                // 真题提交 ID
  variantSubmissionId Int?                // 变形题提交 ID
  content             String             // 完整 AI 响应（含【错误类型：xxx】首行）
  errorType           String             // 提取的错误类型
  createdAt           DateTime   @default(now())
  user                User               @relation(fields: [userId], references: [id])
  problem             Problem?           @relation(fields: [problemId], references: [id])
  variant             VariantProblem?    @relation(fields: [variantId], references: [id])
  submission          Submission?        @relation(fields: [submissionId], references: [id])
  variantSubmission   VariantSubmission? @relation(fields: [variantSubmissionId], references: [id])

  @@unique([userId, problemId])
  @@unique([userId, variantId])
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  problemId Int?                // null 时表示变形题对话
  variantId Int?                // 变形题 ID（与 problemId 二选一）
  role      String             // user | assistant
  content   String
  createdAt DateTime @default(now())
  user      User            @relation(fields: [userId], references: [id])
  problem   Problem?        @relation(fields: [problemId], references: [id])
  variant   VariantProblem? @relation(fields: [variantId], references: [id])
}

model Order {
  id            Int       @id @default(autoincrement())
  userId        Int
  orderNo       String    @unique              // 商户订单号（传给虎皮椒）
  plan          String                         // monthly | quarterly | yearly
  amount        Int                            // 金额（单位：分）
  status        String    @default("pending")  // pending | paid | expired
  transactionId String?                        // 虎皮椒返回的交易号
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])
}

model Prompt {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  category  String   // system_tier1 | system_tier2 | system_tier3 | wrongbook_analysis | exam_review | problem_autotag | testgen_solutions | testgen_inputs | testverify_solution | variantgen_problem | variantgen_solution | variantverify_solution (legacy: system)
  content   String
  variables String   @default("[]") // JSON: ["problem_title", "user_code", ...]
  updatedAt DateTime @updatedAt
}

// ───── 变形题系统 ─────

model VariantProblem {
  id            Int      @id @default(autoincrement())
  sourceId      Int
  title         String
  description   String
  inputFormat   String
  outputFormat  String
  samples       String               // JSON: [{input, output}]
  testCases     String   @default("[]") // JSON: [{input, output}]，永不暴露给用户
  tags          String   @default("[]")
  level         Int
  genStatus     String   @default("pending") // pending | generating | ready | failed
  genError      String?
  genModel      String?
  verifiedAt    DateTime?
  verifiedCount Int      @default(0)
  createdAt     DateTime @default(now())

  source            Problem             @relation(fields: [sourceId], references: [id])
  submissions       VariantSubmission[]
  wrongBooks        WrongBook[]
  wrongBookAnalyses WrongBookAnalysis[]
  chatHistory       ChatHistory[]
}

// 解锁记录：真题 WA → batch=1；batch1 变形题 WA → batch=2
model VariantUnlock {
  id         Int      @id @default(autoincrement())
  userId     Int
  problemId  Int      // 源题 ID
  batch      Int      // 1 或 2
  unlockedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@unique([userId, problemId, batch])
}

model VariantSubmission {
  id         Int      @id @default(autoincrement())
  userId     Int
  variantId  Int
  code       String
  language   String   @default("cpp")
  status     String
  timeUsed   Int?
  memoryUsed Int?
  createdAt  DateTime @default(now())

  user              User               @relation(fields: [userId], references: [id])
  variant           VariantProblem     @relation(fields: [variantId], references: [id])
  wrongBookAnalyses WrongBookAnalysis[]
}

// ───── 每日专注记录 ─────

model DailyFocusLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  date         String               // YYYY-MM-DD
  focusMs      Int      @default(0)
  distractMs   Int      @default(0)
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

// ───── 埋点事件 ─────

model Event {
  id           Int      @id @default(autoincrement())
  type         String                  // page_view | problem_open | ...
  userId       Int?                    // null = 未登录访客
  anonymousId  String                  // 前端 localStorage 生成的 UUID，用于跨登录状态跟踪
  path         String?                 // 页面路径
  problemId    Int?                    // 关联题目（如 problem_open）
  metadata     String?                 // JSON 字符串，存额外上下文
  createdAt    DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([anonymousId, createdAt])
}

// ───── 大模型调用记录（用于成本看板） ─────

model LlmCall {
  id                     Int      @id @default(autoincrement())
  purpose                String                  // chat | wrongbook_analysis | exam_review | testgen | testverify | variantgen | variantverify | problem_autotag
  model                  String                  // claude-opus-4-7 | claude-sonnet-4-6 | ...
  status                 String                  // success | error
  inputTokens            Int      @default(0)
  outputTokens           Int      @default(0)
  cacheReadTokens        Int      @default(0)
  cacheWrite5mTokens     Int      @default(0)
  cacheWrite1hTokens     Int      @default(0)
  costUsd                Float    @default(0)    // 按官方价格估算(USD)
  latencyMs              Int?                    // 端到端耗时
  errorMsg               String?
  createdAt              DateTime @default(now())

  @@index([createdAt])
  @@index([purpose, createdAt])
  @@index([status, createdAt])
}

// ───── 邮箱验证码 ─────

model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String                  // 6 位数字验证码
  type      String                  // register | reset_password
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)    // 验证尝试次数，≥5 自动作废
  createdAt DateTime @default(now())

  @@index([email, type])
}
