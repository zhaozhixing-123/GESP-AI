generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique
  passwordHash        String
  role                String               @default("user") // admin | user
  createdAt           DateTime             @default(now())
  parentPassword      String?              // 家长密码（bcrypt hash）
  feishuWebhook       String?              // 飞书 Webhook URL
  // 账户扩展字段
  phone               String?              // 手机号（选填）
  targetLevel         Int?                 // 目标考试级别 3-8
  examDate            DateTime?            // 目标考试日期
  plan                String               @default("free") // free | monthly | quarterly | yearly
  planExpireAt        DateTime?            // 订阅到期时间，null = 免费用户
  submissions         Submission[]
  wrongBooks          WrongBook[]
  chatHistory         ChatHistory[]
  wrongBookAnalyses   WrongBookAnalysis[]
  orders              Order[]
  variantUnlocks      VariantUnlock[]
  variantSubmissions  VariantSubmission[]
}

model Problem {
  id                  Int                  @id @default(autoincrement())
  luoguId             String               @unique
  title               String
  level               Int                  // 1-8 GESP级别
  description         String
  inputFormat         String
  outputFormat        String
  samples             String               // JSON: [{input, output}]
  testCases           String               // JSON: [{input, output}]
  tags                String               @default("[]") // JSON: ["递推/递归", "动态规划"]
  verifiedAt          DateTime?            // 上次复核时间
  verifiedCount       Int                  @default(0) // 复核通过的测试点数
  submissions         Submission[]
  wrongBooks          WrongBook[]
  chatHistory         ChatHistory[]
  wrongBookAnalyses   WrongBookAnalysis[]
  variants            VariantProblem[]
  variantUnlocks      VariantUnlock[]
}

model Submission {
  id                  Int                  @id @default(autoincrement())
  userId              Int
  problemId           Int
  code                String
  language            String               @default("cpp")
  status              String               // AC, WA, TLE, CE, RE, MLE
  timeUsed            Int?                 // ms
  memoryUsed          Int?                 // KB
  createdAt           DateTime             @default(now())
  user                User                 @relation(fields: [userId], references: [id])
  problem             Problem              @relation(fields: [problemId], references: [id])
  wrongBookAnalyses   WrongBookAnalysis[]
}

model WrongBook {
  id        Int      @id @default(autoincrement())
  userId    Int
  problemId Int?                // null 时表示这是变形题错题
  variantId Int?                // 变形题 ID（与 problemId 二选一）
  addedAt   DateTime @default(now())
  user      User            @relation(fields: [userId], references: [id])
  problem   Problem?        @relation(fields: [problemId], references: [id])
  variant   VariantProblem? @relation(fields: [variantId], references: [id])

  @@unique([userId, problemId])
  @@unique([userId, variantId])
}

model WrongBookAnalysis {
  id                  Int        @id @default(autoincrement())
  userId              Int
  problemId           Int?                // null 时表示变形题分析
  variantId           Int?                // 变形题 ID（与 problemId 二选一）
  submissionId        Int?                // 真题提交 ID
  variantSubmissionId Int?                // 变形题提交 ID
  content             String             // 完整 AI 响应（含【错误类型：xxx】首行）
  errorType           String             // 提取的错误类型
  createdAt           DateTime   @default(now())
  user                User               @relation(fields: [userId], references: [id])
  problem             Problem?           @relation(fields: [problemId], references: [id])
  variant             VariantProblem?    @relation(fields: [variantId], references: [id])
  submission          Submission?        @relation(fields: [submissionId], references: [id])
  variantSubmission   VariantSubmission? @relation(fields: [variantSubmissionId], references: [id])

  @@unique([userId, problemId])
  @@unique([userId, variantId])
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  problemId Int?                // null 时表示变形题对话
  variantId Int?                // 变形题 ID（与 problemId 二选一）
  role      String             // user | assistant
  content   String
  createdAt DateTime @default(now())
  user      User            @relation(fields: [userId], references: [id])
  problem   Problem?        @relation(fields: [problemId], references: [id])
  variant   VariantProblem? @relation(fields: [variantId], references: [id])
}

model Order {
  id            Int       @id @default(autoincrement())
  userId        Int
  orderNo       String    @unique              // 商户订单号（传给虎皮椒）
  plan          String                         // monthly | quarterly | yearly
  amount        Int                            // 金额（单位：分）
  status        String    @default("pending")  // pending | paid | expired
  transactionId String?                        // 虎皮椒返回的交易号
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])
}

model Prompt {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  category  String   // system | hint | error_analysis | step_guide
  content   String
  variables String   @default("[]") // JSON: ["problem_title", "user_code", ...]
  updatedAt DateTime @updatedAt
}

// ───── 变形题系统 ─────

model VariantProblem {
  id            Int      @id @default(autoincrement())
  sourceId      Int
  title         String
  description   String
  inputFormat   String
  outputFormat  String
  samples       String               // JSON: [{input, output}]
  testCases     String   @default("[]") // JSON: [{input, output}]，永不暴露给用户
  tags          String   @default("[]")
  level         Int
  genStatus     String   @default("pending") // pending | generating | ready | failed
  genError      String?
  genModel      String?
  verifiedAt    DateTime?
  verifiedCount Int      @default(0)
  createdAt     DateTime @default(now())

  source            Problem             @relation(fields: [sourceId], references: [id])
  submissions       VariantSubmission[]
  wrongBooks        WrongBook[]
  wrongBookAnalyses WrongBookAnalysis[]
  chatHistory       ChatHistory[]
}

// 解锁记录：真题 WA → batch=1；batch1 变形题 WA → batch=2
model VariantUnlock {
  id         Int      @id @default(autoincrement())
  userId     Int
  problemId  Int      // 源题 ID
  batch      Int      // 1 或 2
  unlockedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@unique([userId, problemId, batch])
}

model VariantSubmission {
  id         Int      @id @default(autoincrement())
  userId     Int
  variantId  Int
  code       String
  language   String   @default("cpp")
  status     String
  timeUsed   Int?
  memoryUsed Int?
  createdAt  DateTime @default(now())

  user              User               @relation(fields: [userId], references: [id])
  variant           VariantProblem     @relation(fields: [variantId], references: [id])
  wrongBookAnalyses WrongBookAnalysis[]
}
